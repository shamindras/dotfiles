#!/usr/bin/env bash
set -Eeuo pipefail

# Close all macOS Notification Center notifications via accessibility API.
# Opens the Notification Center panel (via Clock menu-bar click), then
# repeatedly re-scans and performs "Clear All" on each notification group.
# Re-scanning after each clear avoids stale element references.
#
# Requires: System Settings > Privacy & Security > Accessibility enabled
# for the app executing this script (e.g., Leader Key).

osascript <<'APPLESCRIPT'
tell application "System Events"
    try
        -- Open Notification Center by clicking the Clock in the menu bar
        tell process "ControlCenter"
            set clockItem to (first menu bar item of menu bar 1 whose description is "Clock")
            perform action "AXPress" of clockItem
        end tell

        delay 0.5

        tell process "NotificationCenter"
            set winList to every window
            if (count of winList) = 0 then return

            -- Outer loop: re-scan the element tree after each successful
            -- "Clear All" to avoid stale references from UI mutation.
            repeat
                set cleared to false
                set allElems to entire contents of (item 1 of winList)
                repeat with elem in allElems
                    try
                        set elemActions to every action of elem
                        repeat with act in elemActions
                            set actDesc to description of act
                            if actDesc is "Clear All" then
                                perform act
                                set cleared to true
                                exit repeat
                            end if
                        end repeat
                    end try
                    if cleared then exit repeat
                end repeat
                if not cleared then exit repeat
                delay 0.3
            end repeat
        end tell

        delay 0.5

        -- Close the Notification Center panel
        tell process "ControlCenter"
            set clockItem to (first menu bar item of menu bar 1 whose description is "Clock")
            perform action "AXPress" of clockItem
        end tell
    end try
end tell
APPLESCRIPT
