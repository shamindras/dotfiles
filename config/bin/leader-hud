#!/bin/sh
# leader-hud â€” update sketchybar leader key HUD
#
# Called by kanata at each layer transition to show available keys or
# dismiss the HUD. Handles rootâ†’user context switch internally via
# run-as-user (kanata runs as root, sketchybar runs as the user).
#
# Usage:
#   leader-hud show <group>   Show HUD label for group
#   leader-hud hide           Hide HUD

set -eu

SCRIPT_DIR="$(dirname "$0")"
RUN_AS_USER="$SCRIPT_DIR/run-as-user"

ACTION="${1:?Usage: leader-hud show|hide [group]}"
GROUP="${2:-}"

case "$ACTION" in
  show)
    case "$GROUP" in
      leader)
        LABEL="â–¸ o:َ°ڈ‹ q:َ°…– r:َ°œژ c:َ°ڑ© s:َ°چ‰ g:َ°ٹ¤ u:َ°Œ·"
        ;;
      open)
        LABEL="(o)â–¸ a:َ°ˆ” b:َ°ˆ¹ d:َ°‹© e:َ°‰‹ g:َ°­¹ i:َ°‚½ m:َ°“‡ n:َ°¤¨ p:َ°ˆ™ q:َ°ڈ« s:َ°¨‍ t:َ°ٹ  v:َ°•¼ w:َ°†چ x:َ°‡ڑ 1:َ°Œ‹"
        ;;
      quit)
        LABEL="(q)â–¸ a:َ°ˆ” b:َ°ˆ¹ d:َ°‹© e:َ°‰‹ g:َ°­¹ i:َ°‚½ m:َ°“‡ n:َ°¤¨ p:َ°ˆ™ q:َ°ڈ« s:َ°¨‍ t:َ°ٹ  v:َ°•¼ w:َ°†چ x:َ°‡ڑ 1:َ°Œ‹"
        ;;
      claude)
        LABEL="(c)â–¸ n:َ°ژ” r:َ°‹ڑ u:َ°„¨"
        ;;
      run)
        LABEL="(r)â–¸ b:َ°ڈ— c:َ°‚œ e:َ°ˆ» i:َ°ˆ” m:َ°‰ڈ r:َ°‘“ t:َ°©¹ u:َ°–پ w:َ°›Œ"
        ;;
      search)
        LABEL="(s)â–¸ b:َ°ƒ€ c:َ°…‡ f:َ°ˆ‍"
        ;;
      github)
        LABEL="(g)â–¸ b:َ°–ں c:َ°—€ d:َ°‰‹ g:َ°ٹ¤ n:َ°ژگ"
        ;;
      urls)
        LABEL="(u)â–¸ b:َ°–ں h:َ°‹œ i:َ°—ƒ k:َ°·گ"
        ;;
      *)
        echo "leader-hud: unknown group '$GROUP'" >&2
        exit 1
        ;;
    esac
    "$RUN_AS_USER" sketchybar --set leader label="$LABEL" drawing=on
    ;;
  hide)
    "$RUN_AS_USER" sketchybar --set leader drawing=off
    ;;
  *)
    echo "leader-hud: unknown action '$ACTION'" >&2
    exit 1
    ;;
esac
