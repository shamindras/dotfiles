#!/bin/sh
# run-as-user — execute a command as the console user
#
# When run as root, re-executes the given command as the logged-in
# console user. No-op when already running as a regular user (the
# common path now that Hammerspoon has replaced kanata-as-root). Kept
# around because shared scripts (leader-hud, empty-trash, fastopen)
# still call it as a no-op for forward/backward compatibility.
#
# Usage: run-as-user <command> [args...]

set -eu

if [ "$(id -u)" -eq 0 ]; then
  exec sudo -u "$(stat -f '%Su' /dev/console)" "$@"
else
  exec "$@"
fi
