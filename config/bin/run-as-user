#!/bin/sh
# run-as-user — execute a command as the console user
#
# When run as root, re-executes the given command as the logged-in
# console user. No-op when already running as a regular user. Shared
# scripts (leader-hud, empty-trash, fastopen) call it unconditionally
# so they tolerate being invoked under sudo.
#
# Usage: run-as-user <command> [args...]

set -eu

if [ "$(id -u)" -eq 0 ]; then
  exec sudo -u "$(stat -f '%Su' /dev/console)" "$@"
else
  exec "$@"
fi
