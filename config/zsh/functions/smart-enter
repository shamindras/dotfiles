##? smart-enter - ZLE widget: run eza on empty input, accept line otherwise
##?
##? On empty input + Return: run eza (like `l` alias)
##? On non-empty input: normal command execution (accept-line)
##?
##? usage:
##?   bindkey '^M' smart-enter  # bound in 05-z1-editor.zsh

smart-enter() {
  if [[ -z "$BUFFER" ]]; then
    BUFFER="l"
  fi
  zle accept-line
}

# vim: ft=zsh
