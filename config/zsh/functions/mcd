##? mcd - create a new directory and cd into it using zoxide
##?
##? usage:
##?   mcd <dir>
##?
##? examples:
##?   mcd ~/Projects/new-app    # create and cd into new-app

mcd() {
  [[ "$1" == "-h" || "$1" == "--help" ]] && { grep "^##?" "${(%):-%x}" | cut -c 5-; return 0; }

  mkdir -p -- "$1" && z "$1"
}

# vim: ft=zsh
