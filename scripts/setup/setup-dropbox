#!/usr/bin/env bash
#
# setup-dropbox — install Dropbox and wait for sign-in.
# Thin wrapper around ./bootstrap --setup-only (phases 1-4, no install hand-off).
# For the full bootstrap (Dropbox + ./install), run ./bootstrap directly.

set -Eeuo pipefail

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
exec "${BASEDIR}/bootstrap" --setup-only "$@"
