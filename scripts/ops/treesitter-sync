#!/usr/bin/env bash
# treesitter-sync — update the nvim-treesitter plugin via lazy, then install
# missing + update outdated parsers via setup-nvim-treesitter.
set -Eeuo pipefail

# shellcheck source=../_lib/step.sh
source "$(dirname "$0")/../_lib/step.sh"

step_inner 1 3 "Updating nvim-treesitter plugin via lazy"
nvim --headless -c 'lua require("lazy").update({plugins={"nvim-treesitter"}, wait=true})' -c 'qa' 2>/dev/null || true

step_inner 2 3 "Installing/updating parsers"
"$(dirname "$0")/setup-nvim-treesitter"

step_inner 3 3 "Showing parser status"
"$(dirname "$0")/setup-nvim-treesitter" --status

step_done 🔄 "Treesitter synced"
