#!/usr/bin/env bash
# dump-brewfile — dump current Homebrew packages to ./config/brew/Brewfile.
#
# Strips cargo from PATH so brew doesn't invoke the rustup shim, which errors
# in subprocesses where it can't resolve the default toolchain. Rust/cargo is
# managed separately via rustup, not the Brewfile.
set -Eeuo pipefail

# shellcheck source=../_lib/step.sh
source "$(dirname "$0")/../_lib/step.sh"

step_inner 1 1 "Dumping Homebrew bundle to ./config/brew/Brewfile"
PATH="$(echo "$PATH" | tr ':' '\n' | grep -v cargo | tr '\n' ':')" \
    brew bundle dump --describe --force --file=./config/brew/Brewfile
step_done 🍺 "Brewfile saved to ./config/brew/Brewfile"
