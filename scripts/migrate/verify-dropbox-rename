#!/usr/bin/env bash
set -Eeuo pipefail

# ==============================================================================
# verify-dropbox-rename — Check for stale uppercase DROPBOX references
#
# Scans the home directory for files still containing uppercase "DROPBOX"
# as a filesystem path. Classifies hits as generator (must fix), generated
# (safe to ignore), or external (app-managed).
#
# Usage:
#   ./scripts/migrate/verify-dropbox-rename
#
# Exit codes:
#   0 — No generator files have stale uppercase refs
#   1 — Generator files still need updating
# ==============================================================================

echo "=== verify-dropbox-rename ==="
echo "Scanning for uppercase DROPBOX filesystem references..."
echo ""

# ---------------------------------------------------------------------------
# Known-safe patterns (generated or external — not our responsibility)
#
# Uses --no-ignore --hidden for broad scanning. Exclusions cover:
#   1. Vendored/generated dirs inside repos (.venv, renv, node_modules, etc.)
#   2. External app state (Dropbox, browsers, IDE caches)
#   3. Claude Code transient state
# ---------------------------------------------------------------------------
EXCLUDE_GLOBS=(
  # Version control
  --glob '!.git'
  # Vendored/generated dirs inside repos
  --glob '!.venv'
  --glob '!**/renv/library'
  --glob '!**/.Rproj.user'
  --glob '!**/.rproj.user*'
  --glob '!node_modules'
  --glob '!__pycache__'
  --glob '!.pytest_cache'
  --glob '!.ruff_cache'
  --glob '!**/_site'
  --glob '!**/_freeze'
  --glob '!**/.quarto'
  --glob '!.Trash'
  # XDG state/data/cache (generated by tools)
  --glob '!.local/share'
  --glob '!.local/state'
  --glob '!Library/Caches'
  # Dropbox app state
  --glob '!.dropbox'
  --glob '!Library/Dropbox'
  --glob '!Library/Application Support/Dropbox'
  --glob '!Library/LaunchAgents/com.dropbox.*'
  # Browser-managed (dropbox.com URLs, not filesystem paths)
  --glob '!Library/Application Support/Google'
  --glob '!Library/Application Support/Mozilla'
  --glob '!Library/Application Support/zen'
  --glob '!Library/Application Support/Microsoft Edge'
  --glob '!Library/Application Support/CrashReporter'
  --glob '!Library/CloudStorage'
  --glob '!Library/Metadata'
  # Alfred workflows (generic "Dropbox" mentions, not filesystem paths)
  --glob '!Library/Application Support/Alfred/Alfred.alfredpreferences/workflows'
  # IDE/editor state (auto-updates)
  --glob '!Library/Application Support/gk'
  --glob '!Library/Application Support/virtualenv'
  --glob '!Library/Application Support/taskwarrior-tui'
  --glob '!Library/Containers'
  # Claude Code transient state
  --glob '!.claude.json'
  --glob '!**/.claude/debug'
  --glob '!**/.claude/backups'
  --glob '!**/.claude/file-history'
  --glob '!**/.claude/plans'
  --glob '!**/.claude/projects'
  --glob '!**/.claude/paste-cache'
  --glob '!**/.claude/shell-snapshots'
  --glob '!*.jsonl'
  # LaTeX build artifacts (regenerated)
  --glob '!*.fls'
  --glob '!*.fdb_latexmk'
  # Misc transient
  --glob '!*.log'
  --glob '!*.cache'
)

hits=$(rg --no-ignore --hidden \
  "${EXCLUDE_GLOBS[@]}" \
  -l 'DROPBOX' "$HOME" 2>/dev/null || true)

if [[ -z "$hits" ]]; then
  echo "All clear — no uppercase DROPBOX filesystem refs found."
  exit 0
fi

# ---------------------------------------------------------------------------
# Classify remaining hits
# ---------------------------------------------------------------------------
generators=()
generated=()

while IFS= read -r file; do
  case "$file" in
    # Claude Code state (generated — will be recreated)
    */.claude/*)
      generated+=("$file")
      ;;
    # IDE workspace state (generated — auto-updates on next open)
    */Application\ Support/Code/*|*/Application\ Support/Positron/*)
      generated+=("$file")
      ;;
    # Research data and Overleaf content (not dotfiles generators)
    */firepred/data/*|*/apps/overleaf/*|*/overleaf/*)
      generated+=("$file")
      ;;
    # Quarto/Library caches, containers, and app state
    */.quarto/*|*/Library/Caches/*|*/Library/Containers/*)
      generated+=("$file")
      ;;
    # Library app-managed state (virtualenv, gk, zen browser, etc.)
    */Library/Application\ Support/virtualenv/*|*/Library/Application\ Support/gk/*)
      generated+=("$file")
      ;;
    */Library/Application\ Support/zen/*)
      generated+=("$file")
      ;;
    # Dropbox content (notes, teaching, backup, personal, resources)
    # These are user data files that mention DROPBOX in content, not config
    */dropbox/notes/*|*/dropbox/teaching/*|*/dropbox/backup/*)
      generated+=("$file")
      ;;
    */dropbox/personal/*|*/dropbox/resources/*)
      generated+=("$file")
      ;;
    # XDG state/data dirs (tool-managed state)
    */.local/share/*|*/.local/state/*)
      generated+=("$file")
      ;;
    # This repo's migration scripts (they search FOR "DROPBOX")
    */scripts/migrate/*)
      generated+=("$file")
      ;;
    # This repo's files that use DROPBOX_* variable names (not stale paths)
    */dotfiles/config/*|*/dotfiles/scripts/*)
      generated+=("$file")
      ;;
    # Everything else is a generator that needs fixing
    *)
      generators+=("$file")
      ;;
  esac
done <<< "$hits"

if [[ ${#generated[@]} -gt 0 ]]; then
  echo "Generated files (safe to ignore, will auto-update):"
  printf "  %s\n" "${generated[@]}"
  echo ""
fi

if [[ ${#generators[@]} -gt 0 ]]; then
  echo "GENERATOR files still contain uppercase DROPBOX (MUST FIX):"
  printf "  %s\n" "${generators[@]}"
  echo ""
  echo "Run ./scripts/migrate/update-dropbox-paths to fix external files."
  exit 1
fi

echo "All generator files are clean."
echo "(${#generated[@]} generated file(s) will auto-update on next use.)"
exit 0
