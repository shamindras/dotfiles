# Only format markdown files — ignore everything else
# Step 1: ignore all files and directories
*
# Step 2: un-ignore directories so prettier can traverse into subdirectories
# (without this, a negation like !**/*.md cannot reach files in subdirs,
# because gitignore rules cannot re-include a file whose parent is excluded)
!*/
# Step 3: un-ignore markdown files in any directory
!**/*.md

# Exclude directories we don't own
submods/

# Exclude Claude skill/convention files (precise formatting, REPO-SPECIFIC markers)
.claude/

# Exclude CLAUDE.md files (hand-aligned tables, bold-prefixed lists)
**/CLAUDE.md

# Exclude vendored theme files
config/yazi/flavors/
# Exclude ya pkg-managed plugins (except our hand-rolled ones are fine to touch)
config/yazi/plugins/
